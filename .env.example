# ============================================================
#  Smart Attendance System v9.6 — Environment Configuration
#  Copy this to .env and fill in your values:
#      cp .env.example .env
# ============================================================

# ── Admin credentials (used for /auth/login and /api/login) ─
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
TEACHER_USERNAME=teacher
TEACHER_PASSWORD=teacher123

# ── API settings ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_TOKEN_EXPIRY_HOURS=8
# Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=changeme_generate_a_real_secret_key_here

# ── Camera ───────────────────────────────────────────────────
# 0 = default laptop camera, 1 = external USB camera
CAMERA_INDEX=0

# ── LBPH recognition thresholds ──────────────────────────────
# Higher threshold = more permissive (accept more faces)
# Lower threshold  = stricter (reject more faces)
LBPH_THRESHOLD=120
LBPH_UNKNOWN_MARGIN=100
DLIB_DISTANCE=0.50
MIN_CONFIDENCE_PCT=25
CONFIRM_FRAMES_REQUIRED=2

# ── Liveness detection ────────────────────────────────────────
# Set to true to require blink/movement before marking present
LIVENESS_ON=false
LIVENESS_THRESHOLD=0.28

# ── Notifications (optional) ─────────────────────────────────
SMS_ENABLED=false
EMAIL_ENABLED=false

# ── CORS (add your frontend URLs if running separately) ──────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500
